# Root environment for unified ai-os monorepo.
# Copy to .env and fill values (never commit .env).

# Shared
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
ADMIN_DASHBOARD_PASSWORD=
DASHBOARD_PASSWORD=
BACKEND_DASHBOARD_PASSWORD=

# Backend / bot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Preferred variable names
WHATSAPP_TOKEN=
VERIFY_TOKEN=

# Backward-compatible aliases (either name works)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Required WhatsApp Cloud field
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v18.0

BOOKING_URL=
GOOGLE_SHEETS_WEBHOOK_URL=
ADMIN_ALERT_NUMBER=

# Backend runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
