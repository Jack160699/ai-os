# Root environment for unified ai-os monorepo.
# Copy to .env and fill values (never commit .env).

# Shared
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000
# Server-side inbox proxy (Vercel). Defaults to https://bot.stratxcel.ai if unset.
BOT_API_URL=https://bot.stratxcel.ai
ADMIN_DASHBOARD_PASSWORD=
DASHBOARD_PASSWORD=
BACKEND_DASHBOARD_PASSWORD=
# Set to 1 on Vercel to log server-side inbox proxy thread counts.
INBOX_DEBUG=

# Backend / bot
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Preferred variable names
WHATSAPP_TOKEN=
VERIFY_TOKEN=

# Backward-compatible aliases (either name works)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Required WhatsApp Cloud field
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_API_VERSION=v18.0
# 1 = run lead-flow auto-replies; 0 = store inbound only (inbox / manual / external AI).
WHATSAPP_INBOUND_AUTO_REPLY=1

BOOKING_URL=
GOOGLE_SHEETS_WEBHOOK_URL=
ADMIN_ALERT_NUMBER=
OWNER_NUMBER=

# Backend runtime
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Optional: POST /internal/followups with header X-Followup-Cron-Secret (same value)
FOLLOWUP_CRON_SECRET=

# Razorpay live credentials (primary)
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=
# Backward-compatible aliases (optional fallback)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Dashboard webhook signing secret (Razorpay → your app)
RAZORPAY_LIVE_WEBHOOK_SECRET=
# Backward-compatible alias (optional fallback)
RAZORPAY_WEBHOOK_SECRET=
# Shared secret Next → Flask POST /internal/razorpay-payment (must match Flask env)
INTERNAL_PAYMENT_WEBHOOK_SECRET=
# Fallback customer email on payment links (Razorpay requires email)
RAZORPAY_CUSTOMER_EMAIL_FALLBACK=
# Set to 1 to also email-notify on payment links
RAZORPAY_NOTIFY_EMAIL=0
