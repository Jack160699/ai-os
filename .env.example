# Copy to .env on the server (never commit .env). Loaded with override=True so these values win over shell env.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

WHATSAPP_ACCESS_TOKEN=
# Phone Number ID from Meta (must match the WhatsApp sender you use).
WHATSAPP_PHONE_NUMBER_ID=993296527209625
WHATSAPP_VERIFY_TOKEN=

# Flask dev server only (python run.py). Gunicorn uses gunicorn.conf.py bind instead.
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# WHATSAPP_GRAPH_API_VERSION=v18.0

# Optional Gunicorn tuning (see gunicorn.conf.py)
# GUNICORN_BIND=127.0.0.1:8000
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120
# GUNICORN_LOG_LEVEL=info

# scripts/send_message.py only
# WHATSAPP_TEST_TO=
