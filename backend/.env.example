PORT=3000
NODE_ENV=development
ADMIN_FRONTEND_APP=stratxcel-os

# Meta WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=set_a_strong_random_token_for_meta_console
# Optional: Meta app secret for X-Hub-Signature-256 on POST /webhook
WHATSAPP_APP_SECRET=
WHATSAPP_TOKEN=your_whatsapp_token
PHONE_NUMBER_ID=your_phone_number_id
# Legacy alias still supported
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_HTTP_TIMEOUT_MS=20000
WHATSAPP_RETRIES=2

# OpenAI
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4o-mini
AI_BOT_NAME=Stratxcel AI Growth Partner
OPENAI_TIMEOUT_MS=25000
OPENAI_RETRIES=2
AI_FAILSAFE_MESSAGE=Got your message 👍 Give me a sec, helping you now.

# Supabase (optional)
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
SUPABASE_RETRIES=2
# Unique column on leads for upsert (use "none" if your table has no phone unique)
SUPABASE_LEADS_ON_CONFLICT=phone
# Order messages by created_at (default) or id if created_at missing
SUPABASE_MESSAGES_ORDER=created_at

# Payments (Node backend sole owner)
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CUSTOMER_EMAIL_FALLBACK=
RAZORPAY_NOTIFY_EMAIL=0

# Conversation memory (last N from DB + rolling summary on leads)
MEMORY_HISTORY_LIMIT=10
MEMORY_PER_LINE_CAP=140
MEMORY_COMPACT_BUDGET_CHARS=1600
MEMORY_PROMPT_TAIL_TURNS=4
MEMORY_SUMMARY_ENABLED=1
MEMORY_SUMMARY_MIN_INTERVAL_MS=90000
MEMORY_SUMMARY_REFRESH_MIN_CHARS=450
MEMORY_SUMMARY_REFRESH_MIN_ROWS=3
MEMORY_SUMMARY_MODEL=gpt-4o-mini
MEMORY_SUMMARY_MAX_TOKENS=140
MEMORY_SUMMARY_TIMEOUT_MS=12000
MEMORY_SUMMARY_RETRIES=1

# Phase A: lead_memory table — after each AI reply, refresh last_summary via OpenAI (set 0 to skip extra call; last_contacted_at still updates)
LEAD_MEMORY_SUMMARY_ENABLED=1

# Phase B: ghosted-return detection (days since last_contacted_at on lead_memory)
ADAPTIVE_GHOST_RETURN_DAYS=5

# Phase C: lead_memory revenue follow-up engine (set to 0 to disable; runs on same interval as FOLLOWUP_SCHEDULER)
PHASE_C_REVENUE_FOLLOWUP_ENABLED=1
PHASE_C_FOLLOWUP_SWEEP_LIMIT=20
PHASE_C_MIN_HOURS_BETWEEN_FOLLOWUPS=24

# Webhook dedupe (WhatsApp may retry deliveries)
WEBHOOK_DEDUPE_TTL_MS=86400000
WEBHOOK_DEDUPE_MAX_KEYS=100000

# Ops
LOG_LEVEL=info
LOG_STACK=0
TRUST_PROXY=0
JSON_BODY_LIMIT=512kb

# Sales automation
HOT_LEAD_BUDGET_MIN=30000
FOLLOWUP_SCHEDULER_ENABLED=1
FOLLOWUP_SCHEDULER_INTERVAL_MIN=15

# CEO WhatsApp bridge
OWNER_WHATSAPP_NUMBERS=
CEO_COMMAND_PERMISSIONS=today stats,hot leads,revenue,pending followups,create task,assign lead,start ads,weekly optimization report

# Phase D funnel analytics (WhatsApp). Set PHASE_D_ANALYTICS_ENABLED=0 to disable inserts.
PHASE_D_ANALYTICS_ENABLED=1
# Weekly rollup job (runs from follow-up scheduler tick; Monday ~03:00 UTC). Set to 0 to disable.
PHASE_D_WEEKLY_OPTIMIZER=1
# Lookback window for founder report + weekly job (days).
PHASE_D_REPORT_LOOKBACK_DAYS=7
